<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TechLogic" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">#03A9F4</item>

        <!-- Status Bar Configuration -->
        <!-- This makes the status bar match the top of your gradient -->
        <item name="android:statusBarColor">#E3F2FD</item>
        <!-- This makes the icons (time, battery) dark so they are visible -->
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.TechLogic" parent="Base.Theme.TechLogic" />
</resources>