<?xml version="1.0" encoding="utf-8"?>
<!-- 1. Change root to CoordinatorLayout -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 🧠 DRAWING CANVAS (Background Content) -->
    <!-- Note: We use ConstraintLayout here for the static parts -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            android:id="@+id/header"
            layout="@layout/component_header"
            app:layout_constraintTop_toTopOf="parent"/>

        <com.appdev.techlogic.DiagramView
            android:id="@+id/diagramView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#EEEEEE"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 🟩 BOTTOM PANEL (The Draggable Sheet) -->
    <!-- 2. Add layout_behavior and behavior_peekHeight -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#40C4C4"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="5dp">

            <ImageView
                android:id="@+id/btnBackToCategories"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/back"
                android:visibility="gone" /> <!-- Hidden by default -->

            <TextView
                android:id="@+id/panelTitle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Categories"
                android:textSize="18sp"
                android:layout_marginStart="10dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginEnd="15dp">

                <ImageView
                    android:id="@+id/btnUndo"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:padding="5dp"
                    android:src="@drawable/undo"
                    android:contentDescription="Undo" />

                <ImageView
                    android:id="@+id/btnRedo"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:padding="5dp"
                    android:src="@drawable/redo"
                    android:layout_marginStart="10dp"
                    android:contentDescription="Redo" />
            </LinearLayout>

            <ImageView
                android:id="@+id/btnExpand"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/arrow_up_float" />
        </LinearLayout>
        <!-- Toggle Arrow (The Handle) -->

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/toolRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp" />

    </LinearLayout>


</androidx.coordinatorlayout.widget.CoordinatorLayout>